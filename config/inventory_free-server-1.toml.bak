[options]
	# Измените на 9, чтобы оставить только первые 9 слотов (хотбар)
	availableSlots = 9
	
	# Оставьте пустым, чтобы игроки не могли разблокировать новые слоты предметами
	unlockSlotItem = ""
	
	# Если true, вещи из заблокированных слотов выпадут на землю. Поставьте false, чтобы они просто заблокировались внутри
	dropItemsInLockedSlots = false
